#!/bin/sh
# ──────────────────────────────────────────────────────────────
#  プッシュ前ガード：追跡ファイル全体を最終検査（秘密情報・顧客データ・DB・鍵・PC固有パス）。
#  誤検知で意図的に通す場合のみ: git push --no-verify
# ──────────────────────────────────────────────────────────────
if [ -f scripts/check-no-data.sh ]; then
  if ! bash scripts/check-no-data.sh; then
    echo "" >&2
    echo "push を中止しました。機微情報の混入を除去してください。" >&2
    echo "（誤検知の場合のみ: git push --no-verify）" >&2
    exit 1
  fi
fi
exit 0
