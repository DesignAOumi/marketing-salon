# ──────────────────────────────────────────────────────────────
#  環境変数テンプレート
#  使い方:  cp .env.example .env  して各値を設定する。
#  ※ .env は絶対にコミットしない（.gitignore 済み）。ダミー値のみをこの .env.example に置く。
# ──────────────────────────────────────────────────────────────

# --- データベース ---
# ローカル開発（npm run dev）: prisma/ からの相対で prisma/dev.db を生成する。
#   docker compose 経由ではこの値は compose の environment で
#   file:/app/var/salon.db に上書きされる（永続ボリューム ./var）。
DATABASE_URL="file:./dev.db"

# --- 認証 / セッション ---
# セッション JWT 署名鍵。十分に長いランダム値を設定する。
#   生成例:  openssl rand -base64 48
AUTH_SECRET="generate-with-openssl-rand-base64-48"

# --- 機微フィールド保存時暗号化（AES-256-GCM）の鍵 ---
# 32バイト鍵を hex(64桁) または base64 で設定する。
#   生成例:  openssl rand -hex 32
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# --- 公開URL（OAuthコールバック等で使用 / セッションCookieのSecure判定）---
# https:// の場合のみ Secure Cookie を有効化する。
#   ・localhost / LAN の HTTP 利用（例 http://192.168.x.x:3000）は http:// のままにする
#     （https にすると Secure Cookie が破棄されログインできなくなる）。
#   ・リバースプロキシでHTTPS終端する公開設置では https://your-domain を設定する。
APP_URL="http://localhost:3000"

# --- 初期管理者（任意）---
# 通常は不要。管理者は初回アクセス時のセットアップ・ウィザード（/setup）で作成します。
# CI や自動化で先に作成したい場合のみ ADMIN_EMAIL / ADMIN_PASSWORD を設定（起動時シードが作成）。
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="管理者"
# サロン名はウィザードのサロン情報ステップで入力します（シード時の初期値のみ）。
SALON_NAME="My Salon"

# --- 外部連携（任意 / 既定OFF）。UI設定からの登録でも可。---
# 連携ありAIモード（Claude BYOキー）。未設定なら連携なし（オフライン）で全機能利用可。
ANTHROPIC_API_KEY=""
# Googleカレンダー連携（M5 / Phase 4）。
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
